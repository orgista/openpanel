<?xml version="1.0" encoding="utf-8"?>
<!--
  Kiosk admin credentials (PIN/recovery verifiers) live in the WebView's
  localStorage under this app's data dir. They must never leave the device via
  cloud backup or device-to-device transfer, so exclude everything from both.
  Pairs with android:allowBackup="false" for pre-Android-12 devices.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="root" />
        <exclude domain="file" />
        <exclude domain="database" />
        <exclude domain="sharedpref" />
        <exclude domain="external" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="root" />
        <exclude domain="file" />
        <exclude domain="database" />
        <exclude domain="sharedpref" />
        <exclude domain="external" />
    </device-transfer>
</data-extraction-rules>
